{
  "rules": {
    ".read": false,
    ".write": false,
    "games": {
      "$gameId": {
        "state": {
          ".read": "auth != null && root.child('games/' + $gameId + '/members/' + auth.uid + '/role').val() != null",
          ".write": "auth != null && root.child('games/' + $gameId + '/members/' + auth.uid + '/role').val() === 'editor'"
        },
        "meta": {
          ".read": "auth != null && root.child('games/' + $gameId + '/members/' + auth.uid + '/role').val() != null",
          ".write": "auth != null && root.child('games/' + $gameId + '/members/' + auth.uid + '/role').val() === 'editor'"
        },
        "snapshots": {
          ".read": "auth != null && root.child('games/' + $gameId + '/members/' + auth.uid + '/role').val() != null",
          "$snapshotId": {
            ".write": "auth != null && root.child('games/' + $gameId + '/members/' + auth.uid + '/role').val() === 'editor'"
          }
        },
        "members": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": false
          }
        },
        "codes": {
          ".read": "auth != null && root.child('games/' + $gameId + '/members/' + auth.uid + '/role').val() === 'editor'",
          ".write": false
        }
      }
    },
    "codeMap": {
      ".read": false,
      ".write": false
    }
  }
}
