{
  "scripts": {
    "bump:cache": "node scripts/bump-cache-version.js",
    "bump:cache:check": "node scripts/bump-cache-version.js --check",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:verify": "test \"$(git config --get core.hooksPath)\" = '.githooks'",
    "prepare": "npm run --silent hooks:install"
  },
  "dependencies": {
    "firebase": "^12.12.1",
    "firebase-functions": "^4.9.0",
    "functions": "^1.0.9"
  }
}
